# Copia a .env y rellena (no subas .env al repositorio)

# Local dev (PostgreSQL nativo)
DATABASE_URL=jdbc:postgresql://localhost:5432/<DATABASE_NAME>?currentSchema=<SCHEMA_NAME>
DATABASE_USERNAME=<DATABASE_USER>
DATABASE_PASSWORD=<DATABASE_PASSWORD>

JWT_SECRET=<LONG_RANDOM_SECRET_REPLACE_ME>

# Entorno test — PostgreSQL en la misma red que la app (p. ej. contenedor Dokploy test).
# Localmente puede ser otro Postgres en localhost o el hostname interno que Dokploy asigne al servicio BD.
TEST_DATABASE_URL=jdbc:postgresql://localhost:5432/<TEST_DATABASE_NAME>
TEST_DATABASE_USERNAME=<TEST_DATABASE_USER>
TEST_DATABASE_PASSWORD=<TEST_DATABASE_PASSWORD>

# Entorno prod — PostgreSQL gestionado (tu proveedor)
PROD_DATABASE_URL=jdbc:postgresql://<PROD_DB_HOST>:5432/<PROD_DATABASE_NAME>?sslmode=require
PROD_DATABASE_USERNAME=<PROD_DATABASE_USER>
PROD_DATABASE_PASSWORD=<PROD_DATABASE_PASSWORD>
